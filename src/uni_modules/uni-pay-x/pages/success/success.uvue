<template>
	<view class="app">
		<view class="header">
			<image :src="successImages" class="header-success-image"></image>
			<view><text class="header-success-title-text">支付成功</text></view>
			<view class="header-hr"></view>
		</view>
		<view class="info-box">
			<view class="info-box-amount"><text class="info-box-amount-text">¥ {{ amountFormat(myOptions.getNumber('total_fee')) }}</text></view>
			<view class="info-box-left-circle"></view>
			<view class="info-box-right-circle"></view>
			<view class="info-box-main">
				<view class="info-box-cell">
					<view class="info-box-cell-left"><text class="info-box-cell-left-text">订单编号</text></view>
					<view class="info-box-cell-right"><text class="info-box-cell-right-text">{{ myOptions['order_no'] }}</text></view>
				</view>
			</view>
		</view>
		<!-- 广告位开始 -->
		<view class="uni-ad">
			<!-- 红包广告，uniappx暂不支持-->
			<!-- <ad-interactive v-if="myOptions['adpid']" :adpid="myOptions['adpid']" v-slot:default="{data, loading, error}"
				open-page-path="/uni_modules/uni-pay-x/pages/ad-interactive-webview/ad-interactive-webview" @error="onaderror">
				<view v-if="data" class="ad-interactive">
					<image :src="data.imgUrl" mode="widthFix"></image>
				</view>
			</ad-interactive> -->
		</view>
		<!-- 广告位结束 -->
		<view v-if="myOptions['return_url']" class="button-query" @click="queryOrder"><text class="button-query-text">查看订单</text></view>
		<view class="footer-hr"></view>
	</view>
</template>

<script setup lang="uts">
  const myOptions = ref({
    adpid: "",
    order_no: "",
    out_trade_no: "",
    total_fee: 0,
    pay_date: "",
    return_url: ""
  } as UTSJSONObject)

  const successImages = ref("data:image/png;base64,")

  const color = ref({
    wxpay: "#01be6e",
    alipay: "#108ee9"
  })

  function queryOrder() {
    let return_url = myOptions.value['return_url'] as string;
    let out_trade_no = myOptions.value['out_trade_no'] as string;
    let order_no = myOptions.value['order_no'] as string;
    let url = return_url + `?out_trade_no=${out_trade_no}&order_no=${order_no}`;
    if (url.indexOf("/") != 0) url = `/${url}`;
    uni.navigateTo({
      url,
    });
  }

  function onaderror(e : any) {
    console.log("ad-error", e);
  }

  function amountFormat(totalFee : number | null) : string {
    if (totalFee == null || totalFee == 0) {
      return "0";
    } else {
      return (totalFee / 100).toFixed(2)
    }
  }

  onLoad((options) => {
    myOptions.value['adpid'] = options['adpid'];
    myOptions.value['order_no'] = options['order_no'] != null ? options['order_no'] : "-";
    myOptions.value['out_trade_no'] = options['out_trade_no'];
    if (options['total_fee'] != null) {
      myOptions.value['total_fee'] = parseFloat(options['total_fee'] as string);
    }
    myOptions.value['pay_date'] = options['pay_date'];
    myOptions.value['return_url'] = options['return_url'];
  })
</script>
<style lang="scss" scoped>
  /* uniappx不支持自定义var变量，故此处只能使用 scss 变量*/
  $bgcolor: #f3f3f3;
  $main: #007aff;

  .app {
    background-color: $bgcolor;
    flex: 1;
  }

  .header {
    background-color: $main;
    display: flex;
    align-items: center;
    padding: 40px 15px 25px 15px;
  }

  .header-success-image {
    width: 60px;
    height: 60px;
  }

  .header-success-title-text {
    color: #ffffff;
    font-size: 17px;
    margin-top: 20px;
    font-weight: bold;
  }

  .header-hr {
    margin-top: 20px;
    width: 100%;
    height: 15px;
    border-radius: 10px;
    opacity: 0.1;
    background-color: #000000;
  }

  .info-box {
    margin: 0 25px;
    position: relative;
    margin-top: -32px;
    background-color: #ffffff;
  }

  .info-box-amount {
    height: 75px;
    border-bottom: 2px dashed #f3f3f3;
  }

  .info-box-amount-text {
    line-height: 75px;
    color: $main;
    font-weight: bold;
    font-size: 30px;
    text-align: center;
  }

  .info-box-left-circle {
    background-color: $bgcolor;
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    top: 65px;
    left: -10px;
  }

  .info-box-right-circle {
    background-color: $bgcolor;
    position: absolute;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    top: 65px;
    right: -10px;
  }

  .info-box-main {
    padding: 15px;
  }

  .info-box-cell {
    display: flex;
    flex-direction: row;
  }

  .info-box-cell-left {
    width: 100px;
  }

  .info-box-cell-left-text {
    text-align: left;
    font-size: 13px;
    color: #333333;
  }

  .info-box-cell-right {
    flex: 1;
  }

  .info-box-cell-right-text {
    text-align: right;
    font-size: 13px;
    color: #333333;
  }

  .uni-ad {
    margin-top: 25px;
    min-height: 50px;
  }

  .ad-interactive {
    text-align: center;
  }

  .button-query {
    background-color: $main;
    margin: 25px 30px 0 30px;
    padding: 10px 15px;
    border-radius: 25px;
    box-sizing: border-box;
  }

  .button-query-text {
    color: #ffffff;
    text-align: center;
  }

  /* #ifndef VUE3-VAPOR */
  .button-query:active {
    opacity: 0.7;
  }

  /* #endif */

  .footer-hr {
    height: 50px;
  }
</style>
