import {
    NavigateBackFail,
    NavigateToFail,
    ReLaunchFail,
    RedirectToFail,
    RouteErrorCode,
    SwitchTabFail,
} from './interface.uts'

export class NavigateBackFailImpl extends UniError implements NavigateBackFail {
    override errCode: RouteErrorCode
    constructor(errMsg: string = '', errCode: RouteErrorCode = 4) {
        super('uni-navigateBack', errCode, errMsg)
    }
}

export class NavigateToFailImpl extends UniError implements NavigateToFail {
    override errCode: RouteErrorCode
    constructor(errMsg: string = '', errCode: RouteErrorCode = 4) {
        super('uni-navigateTo', errCode, errMsg)
    }
}

