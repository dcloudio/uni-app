    override errCode: RouteErrorCode
    constructor(errMsg: string = '', errCode: RouteErrorCode = 4) {
        super('uni-redirectTo', errCode, errMsg)
    }
}

export class ReLaunchFailImpl extends UniError implements ReLaunchFail {
    override errCode: RouteErrorCode
    constructor(errMsg: string = '', errCode: RouteErrorCode = 4) {
        super('uni-reLaunch', errCode, errMsg)
    }
}

export class SwitchTabFailImpl extends UniError implements SwitchTabFail {
    override errCode: RouteErrorCode
    constructor(errMsg: string = '', errCode: RouteErrorCode = 4) {
        super('uni-switchTab', errCode, errMsg)
    }
