	 *       "unixVer": "4.65"
	 *     },
	 *    "harmony": {
	 *      "osVer": "5.0.0",
	 *      "uniVer": "4.65",
	 *      "unixVer": "4.65",
	 *      "unixvVer": "5.0"
	 *    }
	 *   }
