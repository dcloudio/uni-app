export type WebViewProgressStyles = {
	color : string.ColorString
}

export type WebViewStyles = {
	progress : WebViewProgressStyles | boolean
}

export type UniWebviewContextLoadDataOptions = {
	/**
	 * 要加载的内容，编码后的字符串
	 * @uniPlatform {
	 *   "app": {
	 *     "android": {
	 *       "osVer": "5.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *     "ios": {
	 *       "osVer": "12.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *    "harmony": {
	 *      "osVer": "5.0.0",
	 *      "uniVer": "4.71",
	 *      "unixVer": "4.71",
	 *      "unixvVer": "5.0"
	 *    }
	 *   }
	 * }
	 */
	data : string,
	/**
	 * 页面的基础 URL
	 * @uniPlatform {
	 *   "app": {
	 *     "android": {
	 *       "osVer": "5.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *     "ios": {
	 *       "osVer": "12.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *    "harmony": {
	 *      "osVer": "5.0.0",
	 *      "uniVer": "4.71",
	 *      "unixVer": "4.71",
	 *      "unixvVer": "5.0"
	 *    }
	 *   }
	 * }
	 */
	baseURL ?: string | null,
	/**
	 * 加载的页面内容类型，默认值为 "text/html"
	 * @defaultValue 'text/html'
	 * @uniPlatform {
	 *   "app": {
	 *     "android": {
	 *       "osVer": "5.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *     "ios": {
	 *       "osVer": "12.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *    "harmony": {
	 *      "osVer": "5.0.0",
	 *      "uniVer": "4.71",
	 *      "unixVer": "4.71",
	 *      "unixvVer": "5.0"
	 *    }
	 *   }
	 * }
	 */
	mimeType ?: string | null,
	/**
	 * 页面内容的编码类型，默认值为 "utf-8"
	 * @defaultValue 'utf-8'
	 * @uniPlatform {
	 *   "app": {
	 *     "android": {
	 *       "osVer": "5.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *     "ios": {
	 *       "osVer": "12.0",
	 *       "uniVer": "x",
	 *       "unixVer": "4.71"
	 *     },
	 *    "harmony": {
	 *      "osVer": "5.0.0",
	 *      "uniVer": "4.71",
	 *      "unixVer": "4.71",
	 *      "unixvVer": "5.0"
	 *    }
	 *   }
	 * }
	 */
	encoding ?: string | null
}

export type UniWebViewContextLoadDataOptions = UniWebviewContextLoadDataOptions

export type UniWebViewElementLoadDataOptions = {
	/**
	 * 要加载的内容，编码后的字符串
	 * @uniPlatform {
	 *   "app": {
	 *     "android": {
	 *       "osVer": "5.0",
