		UniFileSystemManager.writeFile(encoding = encoding, path = filePath, data = data, completionHandler = (success : boolean, error ?: UniFileSystemManagerError) : void => {
			successTmp = success
			errorTmp = error
			semaphore.signal()
		})

		semaphore.wait(timeout = DispatchTime.distantFuture)

		if (errorTmp != null && !successTmp) {
			let err = this.getErrorMessage("writeFileSync", errorTmp!.errorCode, errorTmp!.description)
			console.log(err)
		} else if (successTmp) {
			console.log("writeFileSync:ok")
		}
	}

