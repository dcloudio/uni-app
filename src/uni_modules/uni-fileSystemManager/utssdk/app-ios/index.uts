	truncateSync(filePath : string, length ?: NSNumber) {
		let semaphore = DispatchSemaphore(value = 0)
		let successTmp : boolean = false
		let errorTmp : UniFileSystemManagerError | null = null

		UniFileSystemManager.truncate(filePath = filePath, length = length, completionHandler = (success : boolean, error ?: UniFileSystemManagerError) : void => {
			successTmp = success
			errorTmp = error
			semaphore.signal()
		})

		semaphore.wait(timeout = DispatchTime.distantFuture)

		if (errorTmp != null && !successTmp) {
			let err = this.getErrorMessage("truncateSync", errorTmp!.errorCode, errorTmp!.description)
			console.log(err)
		} else if (successTmp) {
			console.log("truncateSync:ok")
		}
	}

