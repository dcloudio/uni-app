          <text class="uni-subtitle-text">view 组件拍平</text>
          <text class="uni-info">设置值: {{data.flexBasis}}</text>
          <text class="uni-info">获取值: {{data.flexBasisActualFlat}}</text>
          <view class="test-box">
            <view class="test-flex-container">
