      <view>
        <text>flex-basis</text>
        <view class="demo-box">
          <view class="flex-container">
            <view class="common" style="flex-basis: 100px">
              <text>100px</text>
            </view>
            <view class="flex-item green"></view>
            <view class="flex-item blue"></view>
          </view>
          <view class="flex-container">
            <view class="common" style="flex-basis: 100px" flatten>
              <text>100px</text>
            </view>
            <view class="flex-item green"></view>
            <view class="flex-item blue"></view>
          </view>
        </view>
      </view>

