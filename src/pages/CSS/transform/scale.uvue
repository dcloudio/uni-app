				<view style="width: 200px; height: 1px; background-color: #000; transform: scaleY(0.5)" flatten></view>
			</view>

			<text class="uni-title-text uni-common-mt">scroll-view 组件</text>
			<view class="demo-box">
				<view class="scroll-view-item">
					<scroll-view class="scroll-view-base transform" style="transform: scale(1.2);">
						<text>scale(1.2)</text>
					</scroll-view>
				</view>
				<view class="scroll-view-item">
					<scroll-view class="scroll-view-base transform" style="transform: scaleX(0.8);">
						<text>scaleX(0.8)</text>
					</scroll-view>
				</view>
			</view>

			<view class="uni-common-mt">
				<text class="uni-title-text">setProperty 设置与 getPropertyValue 获取 transform (scale) </text>
			</view>

			<view class="test-container">
				<view class="test-item">
					<text class="uni-subtitle-text">view 组件</text>
					<text class="uni-info">设置值: {{data.transformValueDynamic}}</text>
					<text class="uni-info">获取值: {{data.transformActual}}</text>
					<view class="test-box">
						<view ref="viewRefDynamic" class="common-image" :style="{ transform: data.transformValueDynamic }">
							<text style="font-size: 12px;">view</text>
						</view>
					</view>
				</view>

				<view class="test-item">
					<text class="uni-subtitle-text">text 组件</text>
					<text class="uni-info">设置值: {{data.transformValueDynamic}}</text>
					<text class="uni-info">获取值: {{data.transformActualText}}</text>
					<view class="test-box">
						<text ref="textRefDynamic" class="common-text"
							:style="{ transform: data.transformValueDynamic }">text</text>
					</view>
				</view>

				<view class="test-item">
					<text class="uni-subtitle-text">image 组件</text>
					<text class="uni-info">设置值: {{data.transformValueDynamic}}</text>
					<text class="uni-info">获取值: {{data.transformActualImage}}</text>
					<view class="test-box">
						<image ref="imageRefDynamic" class="common-image" :style="{ transform: data.transformValueDynamic }"
							src="/static/test-image/logo.png"></image>
					</view>
				</view>
			</view>

			<view class="test-container">
				<view class="test-item">
					<text class="uni-subtitle-text">view 组件拍平</text>
					<text class="uni-info">设置值: {{data.transformValueDynamic}}</text>
					<text class="uni-info">获取值: {{data.transformActualFlat}}</text>
					<view class="test-box">
						<view ref="viewRefDynamicFlat" class="common-image"
							:style="{ transform: data.transformValueDynamic }" flatten>
							<text style="font-size: 12px;" flatten>view</text>
						</view>
					</view>
				</view>

				<view class="test-item">
					<text class="uni-subtitle-text">text 组件拍平</text>
					<text class="uni-info">设置值: {{data.transformValueDynamic}}</text>
					<text class="uni-info">获取值: {{data.transformActualTextFlat}}</text>
					<view class="test-box">
						<text ref="textRefDynamicFlat" class="common-text" :style="{ transform: data.transformValueDynamic }"
							flatten>text</text>
					</view>
				</view>

				<view class="test-item">
					<text class="uni-subtitle-text">image 组件拍平</text>
					<text class="uni-info">设置值: {{data.transformValueDynamic}}</text>
					<text class="uni-info">获取值: {{data.transformActualImageFlat}}</text>
					<view class="test-box">
						<image ref="imageRefDynamicFlat" class="common-image"
							:style="{ transform: data.transformValueDynamic }" src="/static/test-image/logo.png" flatten>
						</image>
					</view>
				</view>
			</view>

			<view class="uni-common-mt uni-common-mb">
				<text class="uni-tips">第一个枚举值，'' (空字符串) - 空值情况</text>
				<enum-data :items="transformEnum" title="transform 枚举值" @change="radioChangeTransform"
					:compact="true"></enum-data>
				<input-data :defaultValue="data.transformValueDynamic" title="transform 自定义值" type="text"
					@confirm="inputChangeTransform"></input-data>
			</view>

      <text class="uni-title-text uni-common-mt uni-common-mb">native-view 组件</text>
      <view class="demo-box">
      	<view class="scroll-view-item">
      		<native-view class="scroll-view-base transform" style="transform: scale(1.2);"></native-view>
      	</view>
      	<view class="scroll-view-item">
