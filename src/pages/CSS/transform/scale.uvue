		height: 120px;
		padding: 20px;
		background-color: gray;
	}

	.demo-box {
		flex-direction: row;
		justify-content: space-around;
		margin-top: 10px;
		width: 100%;
	}

	.scroll-view-item {
		position: relative;
		width: 180px;
		height: 180px;
		margin: 10px;
		border:#ddd solid 1px;
		overflow: visible;
	}

	.scroll-view-base {
		width: 120px;
		height: 120px;
		align-items: center;
		justify-content: center;
		position: absolute;
		top: 50%;
		left: 50%;
		margin-top: -60px;
